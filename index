<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>UAI Station — Ingeniería en Sistemas</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=DM+Mono:wght@400;500&display=swap');

*{box-sizing:border-box;margin:0;padding:0}

:root{
  /* UAI Dark Maroon Palette */
  --bordo-deep:#1a0408;
  --bordo-dark:#2d0810;
  --bordo-mid:#4a0e1c;
  --bordo-base:#6b1428;
  --bordo-light:#8b1a35;
  --bordo-bright:#a82040;
  --bordo-accent:#c4284e;

  --surface:#1e0b10;
  --surface2:#260d13;
  --surface3:#2f1018;
  --surface4:#3a1520;
  --surface5:#46192a;

  --border:#4a1a26;
  --border2:#5e2233;
  --border3:#732a40;

  --text:#f0dce2;
  --text2:#c4a0ac;
  --text3:#8a606c;
  --text4:#5a3a42;

  --gold:#d4a843;
  --gold2:#e8c070;
  --green:#2d8a5a;
  --green2:#3ab574;
  --red:#e05050;
  --red2:#f07070;
  --blue:#4a7eb5;
  --blue2:#6a9fd4;
  --amber:#c48020;
  --amber2:#e09a30;

  --font: 'DM Sans', system-ui, sans-serif;
  --mono: 'DM Mono', monospace;

  --rad-sm: 6px;
  --rad: 10px;
  --rad-lg: 14px;
}

html{scroll-behavior:smooth}
body{
  background: var(--bordo-deep);
  color: var(--text);
  font-family: var(--font);
  font-size: 14px;
  line-height: 1.5;
  min-height: 100vh;
}

/* ─── LAYOUT ─── */
.app{display:flex;min-height:100vh}

/* SIDEBAR */
.sidebar{
  width: 220px;
  background: var(--surface);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
  position: sticky;
  top: 0;
  height: 100vh;
  overflow-y: auto;
  transition: transform 0.25s;
  z-index: 100;
}

.brand{
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 18px 16px 16px;
  border-bottom: 1px solid var(--border);
}
.brand-icon{
  width: 34px; height: 34px;
  background: var(--bordo-accent);
  border-radius: var(--rad-sm);
  display: flex; align-items: center; justify-content: center;
  font-size: 13px; font-weight: 600; color: #fff;
  flex-shrink: 0;
}
.brand-name{font-size: 15px; font-weight: 600; color: var(--text)}

.nav-section{padding: 8px 0}
.nav-label{
  font-size: 10px;
  color: var(--text4);
  letter-spacing: 0.8px;
  text-transform: uppercase;
  padding: 8px 16px 4px;
}
.nav-item{
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 9px 16px;
  cursor: pointer;
  color: var(--text3);
  font-size: 13px;
  border-left: 2px solid transparent;
  transition: all 0.15s;
  user-select: none;
}
.nav-item:hover{background: var(--surface3); color: var(--text2)}
.nav-item.active{
  background: var(--surface4);
  color: var(--bordo-accent);
  border-left-color: var(--bordo-accent);
}
.nav-icon{width: 15px; height: 15px; flex-shrink: 0; opacity: 0.7}
.nav-item.active .nav-icon{opacity: 1}
.nav-sep{height: 1px; background: var(--border); margin: 4px 0}

/* HAMBURGER */
.hamburger{
  display: none;
  position: fixed;
  top: 12px;
  left: 12px;
  z-index: 200;
  background: var(--surface3);
  border: 1px solid var(--border);
  border-radius: var(--rad-sm);
  padding: 8px;
  cursor: pointer;
}
.hamburger svg{width:18px;height:18px}
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:99}

/* MAIN */
.main{flex:1;min-width:0;overflow-x:hidden}
.page{display:none;padding:24px;max-width:1100px}
.page.active{display:block}

/* ─── TOP BAR ─── */
.top-bar{
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 24px;
  gap: 12px;
  flex-wrap: wrap;
}
.greeting h1{font-size: 22px; font-weight: 600; color: var(--text)}
.greeting p{font-size: 13px; color: var(--text3); margin-top: 2px}

.top-widgets{display:flex;gap:10px;align-items:stretch;flex-wrap:wrap}

.xp-card{
  background: var(--surface3);
  border: 1px solid var(--border2);
  border-radius: var(--rad-lg);
  padding: 12px 16px;
  min-width: 190px;
}
.xp-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px}
.xp-level-tag{font-size:10px;color:var(--gold);font-weight:600;letter-spacing:0.5px}
.xp-counter{font-size:10px;color:var(--text3)}
.xp-bar-wrap{height:4px;background:var(--border);border-radius:2px;margin-bottom:5px}
.xp-bar{height:100%;background:var(--gold);border-radius:2px;transition:width 0.5s}
.xp-title{font-size:13px;font-weight:500;color:var(--text)}

.avance-card{
  background: var(--surface3);
  border: 1px solid var(--border2);
  border-radius: var(--rad-lg);
  padding: 12px 16px;
  text-align: center;
  min-width: 90px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.avance-pct{font-size:24px;font-weight:600;color:var(--bordo-accent)}
.avance-label{font-size:10px;color:var(--text3);margin-top:2px;text-transform:uppercase;letter-spacing:0.5px}

/* ─── CARDS ─── */
.card{
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: var(--rad-lg);
  padding: 16px;
}
.card-inner{
  background: var(--surface3);
  border: 1px solid var(--border);
  border-radius: var(--rad);
  padding: 12px 14px;
}
.sec-title{
  font-size: 10px;
  color: var(--text3);
  font-weight: 600;
  letter-spacing: 0.6px;
  text-transform: uppercase;
  margin-bottom: 12px;
}

/* ─── GRIDS ─── */
.grid2{display:grid;grid-template-columns:1fr 320px;gap:14px;margin-bottom:14px}
.grid4{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:14px}
.grid2b{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.grid2c{display:grid;grid-template-columns:1fr 1fr;gap:14px}

/* ─── STAT MINI ─── */
.stat-mini{
  background: var(--surface3);
  border: 1px solid var(--border);
  border-radius: var(--rad);
  padding: 12px 14px;
}
.stat-mini-label{
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 10px;
  color: var(--text3);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 5px;
}
.stat-mini-num{font-size: 26px; font-weight: 600; color: var(--text)}

/* ─── EXAM CARD ─── */
.exam-hero{
  background: var(--surface2);
  border: 1px solid var(--border2);
  border-left: 3px solid var(--bordo-accent);
  border-radius: var(--rad-lg);
  padding: 18px 20px;
  position: relative;
  overflow: hidden;
}
.exam-badge-label{font-size:10px;color:var(--bordo-accent);font-weight:600;letter-spacing:0.6px;margin-bottom:6px;text-transform:uppercase}
.exam-hero-title{font-size:20px;font-weight:600;color:var(--text);margin-bottom:3px}
.exam-hero-sub{font-size:13px;color:var(--text3);margin-bottom:12px}
.exam-date-pill{
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: var(--surface4);
  border: 1px solid var(--border2);
  border-radius: var(--rad-sm);
  padding: 4px 10px;
  font-size: 11px;
  color: var(--text2);
  margin-bottom: 12px;
}
.exam-countdown{
  position: absolute;
  right: 20px;
  top: 50%;
  transform: translateY(-50%);
  text-align: center;
}
.exam-count-num{font-size:52px;font-weight:700;color:var(--red2);line-height:1}
.exam-count-label{font-size:11px;color:var(--text3)}

/* ─── BUTTONS ─── */
.btn{
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 8px 14px;
  border-radius: var(--rad-sm);
  font-size: 13px;
  font-family: var(--font);
  cursor: pointer;
  border: 1px solid var(--border2);
  background: var(--surface4);
  color: var(--text2);
  transition: all 0.15s;
  white-space: nowrap;
}
.btn:hover{background:var(--surface5);color:var(--text)}
.btn:active{transform:scale(0.98)}
.btn-primary{background:var(--bordo-base);border-color:var(--bordo-light);color:#fff}
.btn-primary:hover{background:var(--bordo-light)}
.btn-accent{background:var(--bordo-accent);border-color:var(--bordo-accent);color:#fff}
.btn-accent:hover{background:var(--bordo-bright)}
.btn-green{background:rgba(45,138,90,0.2);border-color:rgba(58,181,116,0.4);color:var(--green2)}
.btn-green:hover{background:rgba(45,138,90,0.3)}
.btn-sm{padding:5px 10px;font-size:12px}
.btn-icon{padding:5px;border:none;background:transparent;color:var(--text4);cursor:pointer;border-radius:4px}
.btn-icon:hover{color:var(--text2);background:var(--surface4)}
.btn-full{width:100%}

/* ─── INPUTS ─── */
.input{
  background: var(--surface4);
  border: 1px solid var(--border);
  border-radius: var(--rad-sm);
  padding: 8px 12px;
  color: var(--text);
  font-size: 13px;
  font-family: var(--font);
  width: 100%;
  transition: border-color 0.15s;
}
.input:focus{outline:none;border-color:var(--bordo-light)}
.input::placeholder{color:var(--text4)}
.input-label{font-size:11px;color:var(--text3);margin-bottom:4px}

/* ─── MESSAGES ─── */
.msg-item{
  padding: 10px 12px;
  border-left: 2px solid var(--bordo-accent);
  background: var(--surface3);
  border-radius: 0 var(--rad-sm) var(--rad-sm) 0;
  margin-bottom: 8px;
}
.msg-from{font-size:10px;color:var(--bordo-accent);margin-bottom:2px;text-transform:uppercase;letter-spacing:0.4px}
.msg-name{font-size:13px;font-weight:500;color:var(--text);margin-bottom:2px}
.msg-preview{font-size:12px;color:var(--text3)}

/* ─── TASK ─── */
.task-item{
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 0;
  border-bottom: 1px solid var(--border);
}
.task-item:last-child{border-bottom:none}
.chk{
  width:16px;height:16px;
  border:1.5px solid var(--border3);
  border-radius:4px;
  flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;
  transition:all 0.15s;
}
.chk.done{background:var(--green);border-color:var(--green)}
.chk svg{display:none}
.chk.done svg{display:block}
.task-name{flex:1;font-size:13px;color:var(--text);min-width:0}
.task-name.done-text{color:var(--text4);text-decoration:line-through}
.task-mat{font-size:10px;color:var(--text4);margin-top:1px}
.task-date{font-size:11px;color:var(--text3);flex-shrink:0}

/* ─── SUBJECT ─── */
.subjects-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(195px,1fr));gap:7px}
.subject-card{
  background: var(--surface3);
  border: 1px solid var(--border);
  border-left: 3px solid var(--border);
  border-radius: var(--rad-sm);
  padding: 9px 11px;
  cursor: pointer;
  transition: border-color 0.15s, background 0.15s;
}
.subject-card:hover{background:var(--surface4)}
.subject-card.cursando{border-left-color:var(--blue2)}
.subject-card.aprobada{border-left-color:var(--green2)}
.subject-card.final_pendiente{border-left-color:var(--red)}
.subject-card.pendiente{border-left-color:var(--border2)}
.s-code{font-size:10px;color:var(--text4);font-family:var(--mono);margin-bottom:2px}
.s-name{font-size:12px;color:var(--text);line-height:1.35}
.subject-card.aprobada .s-name{color:var(--text4);text-decoration:line-through}
.s-status{font-size:10px;font-weight:500;margin-top:4px}
.s-status.cursando{color:var(--blue2)}
.s-status.aprobada{color:var(--green2)}
.s-status.final_pendiente{color:var(--red2)}
.s-status.pendiente{color:var(--text4)}

.year-header{
  font-size:12px;font-weight:600;color:var(--text2);
  text-transform:uppercase;letter-spacing:0.6px;
  margin:18px 0 8px;
  display:flex;align-items:center;gap:8px;
}
.year-header::after{content:'';flex:1;height:1px;background:var(--border)}
.cuatri-label{font-size:11px;color:var(--text4);margin:10px 0 6px}

/* ─── PROGRESS ─── */
.progress-strip{display:flex;align-items:center;gap:12px;margin-bottom:16px}
.prog-bar{flex:1;height:5px;background:var(--border);border-radius:3px;overflow:hidden}
.prog-fill{height:100%;background:var(--bordo-accent);border-radius:3px;transition:width 0.4s}
.prog-label{font-size:12px;color:var(--text3);min-width:100px;text-align:right}

/* ─── FILTER CHIPS ─── */
.filter-bar{display:flex;gap:6px;margin-bottom:16px;flex-wrap:wrap;align-items:center}
.chip{
  padding:4px 12px;
  border-radius:20px;
  border:1px solid var(--border);
  background:transparent;
  color:var(--text3);
  font-size:12px;
  font-family:var(--font);
  cursor:pointer;
  transition:all 0.15s;
}
.chip:hover{border-color:var(--border2);color:var(--text2)}
.chip.on{background:var(--bordo-base);border-color:var(--bordo-light);color:var(--text)}

/* ─── EXAM LIST ─── */
.exam-list-item{
  display:flex;align-items:center;gap:12px;
  padding:11px 12px;
  background:var(--surface3);
  border-radius:var(--rad-sm);
  margin-bottom:7px;
}
.exam-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.exam-info-wrap{flex:1;min-width:0}
.exam-title-small{font-size:13px;font-weight:500;color:var(--text)}
.exam-mat-small{font-size:11px;color:var(--text3);margin-top:1px}
.exam-days-badge{
  font-size:12px;font-weight:600;
  padding:3px 8px;border-radius:var(--rad-sm);
  flex-shrink:0;
}

/* ─── POMODORO ─── */
.pomo-ring{
  width:170px;height:170px;
  margin:0 auto 14px;
  position:relative;
}
.pomo-ring svg{width:100%;height:100%}
.pomo-time{
  position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  font-size:30px;font-weight:600;color:var(--text);
  font-family:var(--mono);
}
.pomo-mode-btns{display:flex;gap:6px;justify-content:center;margin-bottom:14px;flex-wrap:wrap}
.pomo-btn{
  padding:5px 12px;
  border-radius:20px;
  border:1px solid var(--border2);
  background:transparent;color:var(--text3);
  font-size:12px;font-family:var(--font);
  cursor:pointer;transition:all 0.15s;
}
.pomo-btn.on{background:var(--bordo-base);border-color:var(--bordo-light);color:var(--text)}

/* ─── RPG ─── */
.level-card{
  background:var(--surface3);
  border:1px solid var(--border);
  border-radius:var(--rad);
  padding:12px;
  text-align:center;
}
.level-card.current{border-color:var(--gold);background:rgba(212,168,67,0.06)}
.level-num{font-size:10px;font-weight:600;letter-spacing:0.5px;margin-bottom:3px}
.level-title-sm{font-size:12px;font-weight:500;color:var(--text)}
.level-xp-sm{font-size:10px;color:var(--text4);margin-top:3px}

.xp-log-item{
  display:flex;align-items:center;justify-content:space-between;
  padding:8px 12px;
  background:var(--surface3);
  border-radius:var(--rad-sm);
  margin-bottom:5px;
  font-size:13px;
}
.xp-amount{color:var(--gold2);font-weight:600}

/* ─── BADGE ─── */
.badge{
  display:inline-flex;align-items:center;
  padding:2px 7px;
  border-radius:4px;
  font-size:10px;font-weight:600;
}
.badge-new{background:rgba(100,160,212,0.15);color:var(--blue2)}

/* ─── OBJ ─── */
.obj-item{
  padding:9px 0;
  border-bottom:1px solid var(--border);
}
.obj-item:last-child{border-bottom:none}
.obj-row{display:flex;align-items:center;gap:8px}
.obj-name{flex:1;font-size:13px;color:var(--text)}
.obj-due{font-size:11px;color:var(--text4);margin-top:2px;padding-left:24px}

/* ─── TIPS ─── */
.tip-card{
  padding:12px 14px;
  background:var(--surface3);
  border-radius:var(--rad);
  margin-bottom:8px;
}
.tip-title{font-size:13px;font-weight:500;color:var(--text);margin-bottom:4px}
.tip-body{font-size:12px;color:var(--text3);line-height:1.5}

/* ─── FORM ROW ─── */
.form-row{display:grid;gap:8px;align-items:end}
.form-row-4{grid-template-columns:1fr 1fr 1fr auto}
.form-row-2{grid-template-columns:1fr auto}
.form-row-3{grid-template-columns:1fr 1fr auto}

/* ─── SCROLLBAR ─── */
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px}

/* ─── RESPONSIVE ─── */
@media(max-width:900px){
  .grid2{grid-template-columns:1fr}
  .grid4{grid-template-columns:repeat(2,1fr)}
  .grid2b{grid-template-columns:1fr}
  .grid2c{grid-template-columns:1fr}
  .form-row-4{grid-template-columns:1fr 1fr}
  .exam-countdown{display:none}
}

@media(max-width:700px){
  .sidebar{
    position:fixed;
    left:0;top:0;bottom:0;
    transform:translateX(-100%);
  }
  .sidebar.open{transform:translateX(0)}
  .overlay.show{display:block}
  .hamburger{display:flex;align-items:center}
  .main{padding-top:0}
  .page{padding:60px 14px 20px}
  .top-bar{flex-direction:column;align-items:flex-start}
  .top-widgets{width:100%;flex-direction:column}
  .xp-card,.avance-card{width:100%;min-width:unset}
  .grid4{grid-template-columns:repeat(2,1fr)}
  .form-row-4{grid-template-columns:1fr}
  .form-row-3{grid-template-columns:1fr}
  .form-row-4 .btn,.form-row-3 .btn{width:100%}
  .subjects-grid{grid-template-columns:1fr}
  .top-widgets{flex-direction:row;flex-wrap:wrap}
}

@media(max-width:400px){
  .grid4{grid-template-columns:1fr 1fr}
  .pomo-mode-btns{flex-direction:column;align-items:center}
}
</style>
</head>
<body>

<button class="hamburger" id="hamburger-btn" onclick="toggleSidebar()">
  <svg viewBox="0 0 18 18" fill="currentColor"><rect y="2" width="18" height="2" rx="1"/><rect y="8" width="18" height="2" rx="1"/><rect y="14" width="18" height="2" rx="1"/></svg>
</button>
<div class="overlay" id="sidebar-overlay" onclick="toggleSidebar()"></div>

<div class="app">
<!-- SIDEBAR -->
<div class="sidebar" id="sidebar">
  <div class="brand">
    <div class="brand-icon">U</div>
    <div>
      <div class="brand-name">UAI Station</div>
    </div>
  </div>
  <div class="nav-section">
    <div class="nav-label">Principal</div>
    <div class="nav-item active" data-page="dashboard">
      <svg class="nav-icon" viewBox="0 0 16 16" fill="currentColor"><rect x="1" y="1" width="6" height="6" rx="1"/><rect x="9" y="1" width="6" height="6" rx="1"/><rect x="1" y="9" width="6" height="6" rx="1"/><rect x="9" y="9" width="6" height="6" rx="1"/></svg>
      Dashboard
    </div>
    <div class="nav-item" data-page="materias">
      <svg class="nav-icon" viewBox="0 0 16 16" fill="currentColor"><path d="M2 2h12v1.5H2zm0 3.5h12V7H2zm0 3.5h8v1.5H2zm0 3.5h6V14H2z"/></svg>
      Materias
    </div>
    <div class="nav-item" data-page="examenes">
      <svg class="nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3"><rect x="2" y="1.5" width="12" height="13" rx="1.5"/><path d="M5 5h6M5 8h6M5 11h3" stroke-linecap="round"/></svg>
      Exámenes
    </div>
    <div class="nav-item" data-page="tareas">
      <svg class="nav-icon" viewBox="0 0 16 16" fill="currentColor"><path d="M2 4h12v1.5H2zm0 4h9v1.5H2zm0 4h7v1.5H2z"/></svg>
      Tareas
    </div>
    <div class="nav-item" data-page="objetivos">
      <svg class="nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3"><circle cx="8" cy="8" r="6"/><circle cx="8" cy="8" r="3"/><circle cx="8" cy="8" r="1" fill="currentColor" stroke="none"/></svg>
      Objetivos
    </div>
  </div>
