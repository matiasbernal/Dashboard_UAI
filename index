      <div class="level-title-sm" style="color:${l.level<=c.level?'var(--text)':'var(--text4)'}">${l.title}</div>
      <div class="level-xp-sm">${l.xp.toLocaleString()} XP${l.level===c.level?' — actual':''}</div>
    </div>`).join('');
  const log=document.getElementById('xp-log-list');
  log.innerHTML=ST.xpLog.length
    ?ST.xpLog.slice(0,12).map(e=>`<div class="xp-log-item"><span style="color:var(--text2)">${e.reason}</span><span class="xp-amount">+${e.n} XP</span></div>`).join('')
    :'<div style="color:var(--text4);font-size:13px;padding:8px">Sin actividad aún.</div>';
}

/* ── MATERIAS ── */
let matFilter='todas';
function getMat(code){return ST.materias[code]||'pendiente';}
function cycleMat(code){
  const order={pendiente:'cursando',cursando:'aprobada',aprobada:'final_pendiente',final_pendiente:'pendiente'};
  const prev=getMat(code),next=order[prev];
  ST.materias[code]=next;
  if(next==='aprobada')addXP(500,'Materia aprobada: '+code);
  SAVE();renderMaterias();renderDashStats();renderXP();
}
function resetMaterias(){if(confirm('¿Resetear estado de todas las materias?')){ST.materias={};SAVE();renderMaterias();renderDashStats();}}

function renderMaterias(){
  let ap=0,cu=0,fp=0;
  MATERIAS.forEach(y=>y.cuatris.forEach(c=>c.subs.forEach(s=>{
    const st=getMat(s.code);
    if(st==='aprobada')ap++;else if(st==='cursando')cu++;else if(st==='final_pendiente')fp++;
  })));
  document.getElementById('mat-prog-fill').style.width=Math.round(ap/51*100)+'%';
  document.getElementById('mat-prog-label').textContent=ap+' / 51 aprobadas';
  const LABELS={aprobada:'Aprobada',cursando:'Cursando',final_pendiente:'Final pendiente',pendiente:'Pendiente'};
  document.getElementById('materias-container').innerHTML=MATERIAS.map(y=>{
    const cuHTML=y.cuatris.map(c=>{
      const sHTML=c.subs.map(s=>{
        const st=getMat(s.code);
        if(matFilter!=='todas'&&st!==matFilter)return'';
        return`<div class="subject-card ${st}" onclick="cycleMat('${s.code}')">
          <div class="s-code">${s.code}</div>
          <div class="s-name">${s.name}</div>
          <div class="s-status ${st}">${LABELS[st]}</div>
        </div>`;
      }).join('');
      return sHTML.trim()?`<div class="cuatri-label">${c.name}</div><div class="subjects-grid">${sHTML}</div>`:'';
    }).join('');
    return cuHTML.trim()?`<div class="year-header">${y.year}</div>${cuHTML}`:'';
  }).join('');
}

/* ── DASH STATS ── */
function renderDashStats(){
  let ap=0,cu=0,fp=0;
  MATERIAS.forEach(y=>y.cuatris.forEach(c=>c.subs.forEach(s=>{
    const st=getMat(s.code);
    if(st==='aprobada')ap++;else if(st==='cursando')cu++;else if(st==='final_pendiente')fp++;
  })));
  document.getElementById('s-aprobadas').textContent=ap;
  document.getElementById('s-cursando').textContent=cu;
  document.getElementById('s-finales').textContent=fp;
  document.getElementById('dash-pct').textContent=Math.round(ap/51*100)+'%';
}

/* ── EXAMENES ── */
function renderExamenes(){
  const today=new Date();today.setHours(0,0,0,0);
  const sorted=[...ST.examenes].sort((a,b)=>new Date(a.fecha)-new Date(b.fecha));
  const wrap=document.getElementById('exam-list-wrap');
  if(!sorted.length){
    wrap.innerHTML='<div class="card" style="color:var(--text3);font-size:13px">No hay exámenes cargados aún.</div>';
    document.getElementById('eh-title').textContent='Sin exámenes cargados';
    document.getElementById('eh-sub').textContent='—';
    document.getElementById('eh-date').style.display='none';
    document.getElementById('eh-countdown').style.display='none';
    return;
  }
  const up=sorted.filter(e=>new Date(e.fecha+'T00:00:00')>=today);
  if(up.length){
    const nx=up[0];
    const diff=Math.round((new Date(nx.fecha+'T00:00:00')-today)/864e5);
    document.getElementById('eh-title').textContent=nx.nombre;
    document.getElementById('eh-sub').textContent=nx.materia;
    document.getElementById('eh-date-str').textContent=new Date(nx.fecha+'T00:00:00').toLocaleDateString('es-AR',{weekday:'long',day:'numeric',month:'long'}).toUpperCase();
    document.getElementById('eh-date').style.display='inline-flex';
    document.getElementById('eh-countdown').style.display='block';
    document.getElementById('eh-days').textContent=diff;
  }
  wrap.innerHTML='<div class="card"><div class="sec-title">Todos los exámenes</div>'+
    sorted.map(e=>{
      const diff=Math.round((new Date(e.fecha+'T00:00:00')-today)/864e5);
      const col=diff<0?'var(--text4)':diff<=2?'var(--red2)':diff<=7?'var(--amber2)':'var(--green2)';
      const lbl=diff<0?'Pasado':diff===0?'Hoy':diff===1?'Mañana':(diff+' días');
      return`<div class="exam-list-item">
        <div class="exam-dot" style="background:${col}"></div>
        <div class="exam-info-wrap">
          <div class="exam-title-small">${e.nombre}</div>
          <div class="exam-mat-small">${e.materia} · ${new Date(e.fecha+'T00:00:00').toLocaleDateString('es-AR')}</div>
        </div>
        <div class="exam-days-badge" style="color:${col}">${lbl}</div>
        <button class="btn-icon" onclick="delExamen(${e.id})">✕</button>
      </div>`;
    }).join('')+'</div>';
}

function addExamen(){
  const n=document.getElementById('ex-nombre').value.trim();
  const m=document.getElementById('ex-mat').value.trim();
  const f=document.getElementById('ex-fecha').value;
  if(!n||!f)return;
  ST.examenes.push({id:Date.now(),nombre:n,materia:m||'General',fecha:f});
  document.getElementById('ex-nombre').value='';
  document.getElementById('ex-mat').value='';
  document.getElementById('ex-fecha').value='';
  SAVE();renderExamenes();
}
function delExamen(id){ST.examenes=ST.examenes.filter(e=>e.id!==id);SAVE();renderExamenes();}

/* ── TAREAS ── */
const checkSVG=`<svg width="10" height="10" viewBox="0 0 10 10" fill="none"><polyline points="1.5,5 4,7.5 8.5,2.5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`;

function renderTasks(){
  const pending=ST.tasks.filter(t=>!t.done);
  const done=ST.tasks.filter(t=>t.done);
  const tHTML=t=>`<div class="task-item">
    <div class="chk${t.done?' done':''}" onclick="toggleTask(${t.id})">${t.done?checkSVG:''}</div>
    <div style="flex:1;min-width:0">
      <div class="task-name${t.done?' done-text':''}">${t.name}</div>
      ${t.mat?`<div class="task-mat">${t.mat}</div>`:''}
    </div>
    <div class="task-date">${t.date?new Date(t.date+'T00:00:00').toLocaleDateString('es-AR',{day:'numeric',month:'short'}):''}</div>
    <button class="btn-icon" onclick="delTask(${t.id})">✕</button>
  </div>`;
  document.getElementById('tasks-pending').innerHTML=pending.length?pending.map(tHTML).join(''):'<div style="color:var(--text4);font-size:13px;padding:6px 0">Sin tareas pendientes.</div>';
  document.getElementById('tasks-done').innerHTML=done.length?done.map(tHTML).join(''):'<div style="color:var(--text4);font-size:13px;padding:6px 0">Nada completado aún.</div>';
  const dt=document.getElementById('dash-tasks');
  dt.innerHTML=pending.slice(0,4).map(t=>`<div class="task-item">
    <div class="chk" onclick="toggleTask(${t.id})"></div>
    <div class="task-name">${t.name}</div>
    <div class="task-date">${t.date?new Date(t.date+'T00:00:00').toLocaleDateString('es-AR',{day:'numeric',month:'short'}):''}</div>
  </div>`).join('')||'<div style="color:var(--text4);font-size:13px;padding:6px 0">Sin tareas pendientes.</div>';
}

function addTask(){
  const n=document.getElementById('task-name').value.trim();
  if(!n)return;
  const d=document.getElementById('task-date').value;
  const m=document.getElementById('task-mat').value.trim();
  ST.tasks.push({id:Date.now(),name:n,date:d,mat:m,done:false});
  document.getElementById('task-name').value='';
  document.getElementById('task-date').value='';
  document.getElementById('task-mat').value='';
  SAVE();renderTasks();
}
function toggleTask(id){
  const t=ST.tasks.find(t=>t.id===id);if(!t)return;
  t.done=!t.done;
  if(t.done)addXP(20,'Tarea completada: '+t.name);
  SAVE();renderTasks();renderXP();
}
function delTask(id){ST.tasks=ST.tasks.filter(t=>t.id!==id);SAVE();renderTasks();}

/* ── OBJETIVOS ── */
function renderObjetivos(){
  const active=ST.objetivos.filter(o=>!o.done);
  const done=ST.objetivos.filter(o=>o.done);
  const oHTML=o=>`<div class="obj-item">
    <div class="obj-row">
      <div class="chk${o.done?' done':''}" onclick="toggleObj(${o.id})">${o.done?checkSVG:''}</div>
      <div class="obj-name${o.done?' done-text':''}">${o.name}</div>
      <button class="btn-icon" onclick="delObj(${o.id})">✕</button>
    </div>
    ${o.date?`<div class="obj-due">Vence ${new Date(o.date+'T00:00:00').toLocaleDateString('es-AR')}</div>`:''}
  </div>`;
  document.getElementById('obj-active').innerHTML=active.length?active.map(oHTML).join(''):'<div style="color:var(--text4);font-size:13px;padding:6px 0">Sin objetivos activos.</div>';
  document.getElementById('obj-done').innerHTML=done.length?done.map(oHTML).join(''):'<div style="color:var(--text4);font-size:13px;padding:6px 0">Nada completado aún.</div>';
  document.getElementById('dash-objs').innerHTML=active.slice(0,3).map(o=>`<div class="obj-item">
    <div class="obj-name">${o.name}</div>
    ${o.date?`<div class="obj-due">Vence ${new Date(o.date+'T00:00:00').toLocaleDateString('es-AR')}</div>`:''}
  </div>`).join('')||'<div style="color:var(--text4);font-size:13px;padding:6px 0">Sin objetivos activos.</div>';
}
function addObj(){
  const n=document.getElementById('obj-name').value.trim();if(!n)return;
  const d=document.getElementById('obj-date').value;
  ST.objetivos.push({id:Date.now(),name:n,date:d,done:false});
  document.getElementById('obj-name').value='';document.getElementById('obj-date').value='';
  SAVE();renderObjetivos();
}
function toggleObj(id){
  const o=ST.objetivos.find(o=>o.id===id);if(!o)return;
  o.done=!o.done;if(o.done)addXP(50,'Objetivo completado: '+o.name);
  SAVE();renderObjetivos();renderXP();
}
function delObj(id){ST.objetivos=ST.objetivos.filter(o=>o.id!==id);SAVE();renderObjetivos();}

/* ── POMODORO ── */
let pomoTimer=null,pomoRunning=false,pomoSec=25*60,pomoMax=25*60,pomoMode='work';
const POMO={work:{s:25*60,label:'Sesión de foco',color:'var(--bordo-accent)'},short:{s:5*60,label:'Descanso corto',color:'var(--green2)'},long:{s:15*60,label:'Descanso largo',color:'var(--blue2)'}};

function setPomoMode(mode,btn){
  document.querySelectorAll('.pomo-btn').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  pomoMode=mode;pomoSec=POMO[mode].s;pomoMax=POMO[mode].s;
  document.getElementById('pomo-mode-label').textContent=POMO[mode].label;
  if(pomoTimer){clearInterval(pomoTimer);pomoTimer=null;pomoRunning=false;}
  document.getElementById('pomo-play-btn').textContent='Iniciar';
  updatePomo();
}
function updatePomo(){
  const m=Math.floor(pomoSec/60),s=pomoSec%60;
  document.getElementById('pomo-display').textContent=(m<10?'0':'')+m+':'+(s<10?'0':'')+s;
  const circ=452,pct=pomoSec/pomoMax;
  const arc=document.getElementById('pomo-arc');
  arc.setAttribute('stroke-dashoffset',circ*pct);
  arc.setAttribute('stroke',POMO[pomoMode].color);
}
function pomoPause(){
  if(pomoRunning){clearInterval(pomoTimer);pomoRunning=false;document.getElementById('pomo-play-btn').textContent='Reanudar';}
  else{
    pomoRunning=true;document.getElementById('pomo-play-btn').textContent='Pausar';
    pomoTimer=setInterval(()=>{
      if(pomoSec<=0){
        clearInterval(pomoTimer);pomoRunning=false;
        document.getElementById('pomo-play-btn').textContent='Iniciar';
        if(pomoMode==='work'){ST.pomoSess++;SAVE();document.getElementById('pomo-sess-count').textContent=ST.pomoSess;}
        pomoSec=pomoMax;updatePomo();return;
      }
      pomoSec--;updatePomo();
    },1000);
  }
}
function pomoReset(){if(pomoTimer)clearInterval(pomoTimer);pomoRunning=false;pomoSec=pomoMax;document.getElementById('pomo-play-btn').textContent='Iniciar';updatePomo();}

/* ── NAVIGATION ── */
function goPage(id){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.getElementById('page-'+id).classList.add('active');
  document.querySelector('[data-page="'+id+'"]').classList.add('active');
  if(id==='rpg'){renderRPGGrid();}
  if(window.innerWidth<=700){toggleSidebar(true);}
  window.scrollTo(0,0);
}
document.querySelectorAll('.nav-item').forEach(item=>{
  item.addEventListener('click',()=>goPage(item.dataset.page));
});
document.querySelectorAll('[data-mf]').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('[data-mf]').forEach(b=>b.classList.remove('on'));
    btn.classList.add('on');matFilter=btn.dataset.mf;renderMaterias();
  });
});

/* ── SIDEBAR TOGGLE (mobile) ── */
function toggleSidebar(forceClose){
  const sb=document.getElementById('sidebar');
  const ov=document.getElementById('sidebar-overlay');
  if(forceClose||sb.classList.contains('open')){
    sb.classList.remove('open');ov.classList.remove('show');
  } else {
    sb.classList.add('open');ov.classList.add('show');
  }
}

/* ── GREETING ── */
function setGreeting(){
  const h=new Date().getHours();
  document.getElementById('dash-greeting').textContent=h<12?'Buenos días!':h<19?'Buenas tardes!':'Buenas noches!';
}

/* ── INIT ── */
LOAD();
setGreeting();
renderDashStats();
renderMaterias();
renderExamenes();
renderTasks();
renderObjetivos();
renderXP();
updatePomo();
document.getElementById('pomo-sess-count').textContent=ST.pomoSess||0;
</script>
