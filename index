let ST={materias:{},examenes:[],tasks:[],objetivos:[],xp:0,xpLog:[],pomoSess:0};
const SAVE=()=>{try{localStorage.setItem('uaiSt3',JSON.stringify(ST));}catch(e){}};
const LOAD=()=>{try{const s=localStorage.getItem('uaiSt3');if(s)ST=Object.assign(ST,JSON.parse(s));}catch(e){}};

/* ── XP / RPG ── */
function addXP(n,reason){ST.xp+=n;ST.xpLog.unshift({n,reason,ts:Date.now()});if(ST.xpLog.length>40)ST.xpLog.pop();SAVE();}
function curLevel(){let c=RPG_LEVELS[0];for(const l of RPG_LEVELS)if(ST.xp>=l.xp)c=l;return c;}
function nxtLevel(){for(const l of RPG_LEVELS)if(l.xp>ST.xp)return l;return null;}
function xpPct(){const c=curLevel(),n=nxtLevel();return n?Math.round((ST.xp-c.xp)/(n.xp-c.xp)*100):100;}

function renderXP(){
  const c=curLevel(),n=nxtLevel();
  const pct=xpPct();
  const tag='Nivel '+c.level;
  const ctr=n?(ST.xp+' / '+n.xp+' XP'):(ST.xp+' XP');
  document.getElementById('xp-level-tag').textContent=tag;
  document.getElementById('xp-counter-lbl').textContent=ctr;
  document.getElementById('xp-title-main').textContent=c.title;
  document.getElementById('xp-bar-main').style.width=pct+'%';
  document.getElementById('rpg-title-big').textContent=c.title;
  document.getElementById('rpg-level-big').textContent='Nivel '+c.level;
  document.getElementById('rpg-xp-cur').textContent=ST.xp+' XP acumulados';
  document.getElementById('rpg-xp-nxt').textContent=n?((n.xp-ST.xp)+' XP para nivel '+n.level):'¡Nivel máximo!';
  document.getElementById('rpg-bar-big').style.width=pct+'%';
}

